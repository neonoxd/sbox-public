@namespace MenuProject.Modals
@inherits MenuProject.Modals.BaseModal

@using Sandbox;
@using Sandbox.UI;
@using Menu;
@using System;
@using Sandbox.Modals;
@using Sandbox.DataModel;

<root>
    <div class="window">
        <PackageHero Package="@Package" class="header">
            <Actions>
                <column class="header-title">
                    <label class="medium">Create Game</label>
                </column>
            </Actions>
        </PackageHero>

        <div class="body">
            <div class="tabs">
                <div @onclick=@( () => CurrentTabName = null ) class="@ActiveClass( null )">General</div>

                @foreach ( var group in Settings
                    .GroupBy( x => x.Group )
                    .Where( x => x.Key != "General" && x.Key != null )
                    .OrderBy( x => GetGroupName( x.Key ), StringComparer.OrdinalIgnoreCase ) )
                {
                    <div @onclick=@( () => CurrentTabName = group.Key ) class="@ActiveClass( group.Key )">@GetGroupName( group.Key )</div>
                }
            </div>

            <div class="content">
                @{ 
                    var settings = Settings
                        .Where( x => x.Group == CurrentTabName && Output.GameSettings.ContainsKey( x.Name ) )
                        .OrderBy( x => x.Title, StringComparer.OrdinalIgnoreCase )
                        .ThenBy( x => x.Name, StringComparer.OrdinalIgnoreCase )
                        .ToList();
                }

                @if ( CurrentTabName == null || CurrentTabName == "General" )
                {
                    @if ( IsMultiplayerGame )
                    {
						<div class="row">
                            <div class="is-label">Server Name</div>
                            <div class="control">
                                 <TextEntry Value:bind=@ServerName />
                            </div>
                        </div>

						<div class="row">
                            <div class="is-label">Privacy</div>
                            <div class="control">
								<ButtonGroup class="bg-round" Value:bind=@Privacy >
									<ChildContent>
										@{foreach (var item in TypeLibrary.GetEnumDescription(typeof(Sandbox.Network.LobbyPrivacy)))
										{
											<Button class="clicky" Text=@item.Title Icon=@item.Icon Value=@item.ObjectValue />
										}}
									</ChildContent>
								</ButtonGroup>
                            </div>
                        </div>

                        @if ( MinPlayers != MaxPlayers )
                        {
							<div class="row">
                                <div class="is-label">Max Players</div>
                                <div class="control">
                                    <SliderControl class="glass with-grow" Value:bind=@Players Min=@MinPlayers Max=@MaxPlayers Step=@(1) ShowTextEntry=@true />
                                </div>
                            </div>
                        }
                    }

                    if ( NeedsMap() )
                    {
						<div class="row">
                            <div class="is-label">Map</div>
                            <div class="control">
								<MapSelector Map=@Map OnValueChanged=@OnMapSelected />
                            </div>
                        </div>
                    }
                }

                @foreach ( var e in settings )
                {
                    <div class="row">
                        <div class="is-label">@e.Title.ToTitleCase()</div>
                        <div class="control">
                            @if ( HasOptions( e ) )
                            {
                                <DropDown Value=@Output.GameSettings[e.Name] ValueChanged=@((string x) => { Output.GameSettings[e.Name] = x; }) BuildOptions=@( () => GetOptions(e) )></DropDown>
                            }
                            else if ( IsCheckbox( e ) )
                            {
								<ButtonGroup class="bg-round" Value=@(Output.GameSettings[e.Name].ToBool()) ValueChanged=@((object x) => { Output.GameSettings[e.Name] = x.ToString(); })>
									<ChildContent>
										<Button class="clicky" Text="Off" Value="@false"></Button>
										<Button class="clicky" Text="On" Value="@true"></Button>
									</ChildContent>
								</ButtonGroup>
                            }
                            else if ( IsNumeric( e, out var flValue ) )
                            {
                                @if ( e.Max is not null ) 
                                {
                                    <SliderControl Value=@(Output.GameSettings[e.Name].ToFloat()) OnValueChanged=@((float x) => { Output.GameSettings[e.Name] = x.ToString(); }) class="glass with-grow" Min="@(e.Min ?? 0)" Max="@(e.Max ?? 100)" Step="@(e.Step ?? 1)" ShowTextEntry="@true" />
                                }
                                else
                                {
                                    <TextEntry Value=@Output.GameSettings[e.Name] OnTextEdited=@((string x) => { Output.GameSettings[e.Name] = x; }) />
                                }

                            }
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="footer">
            <Button class="primary" Icon="play_arrow" onclick=@OnSave>Start Game</Button>
        </div>
    </div>
</root>

@code
{
	public List<GameSetting> Settings { get; set; }
	public string Map { get; set; }
	public Sandbox.Network.LobbyPrivacy Privacy { get; set; }

	public Action<CreateGameResults> OnComplete { get; set; }

	CreateGameResults Output { get; set; }
	Package Package { get; set; }

	string CookieName => $"{Package.FullIdent}_create_game_config";
	string CurrentTabName;

	//
	// Multiplayer Settings
	// 

	int MaxPlayers => Package.Info.MaxPlayers;
	int MinPlayers => Package.Info.MinPlayers;
	bool IsMultiplayerGame => Package.Tags.Contains( "multiplayer" ) || Package.Info.MaxPlayers > 1;
	string ServerName { get; set; }
	int Players { get; set; }

	public CreateGameModal( Sandbox.Modals.CreateGameOptions options )
	{
		Package = options.Package;
		OnComplete = options.OnComplete;

		//
		// Check if we have a saved config
		//
		Output = Game.Cookies.Get<CreateGameResults>( CookieName, new()
        {
            MaxPlayers = MinPlayers,
            ServerName = $"{Sandbox.Utility.Steam.PersonaName}'s game"
        } );

		//
		// Apply config / defaults
		//
		Players = Output.MaxPlayers;
		ServerName = Output.ServerName;
		Settings = Package.Info.GameSettings ?? new List<GameSetting>();

		//
		// Verify cookie data
		//
		if ( Players < MinPlayers )
		{
			Players = MinPlayers;
		}
		if ( string.IsNullOrEmpty( ServerName ) )
		{
			ServerName = $"{Sandbox.Utility.Steam.PersonaName}'s game";
		}

		//
		// Initialize GameSettings dictionary with defaults if missing
		//

        foreach ( var setting in Settings )
        {
            if ( !Output.GameSettings.TryGetValue( setting.Name, out var value ) )
            {
                Output.GameSettings[setting.Name] = GetDefaultValue( setting );
                continue;
            }

            if ( HasOptions( setting ) )
            {
                Output.GameSettings[setting.Name] = GetOptionValue( setting, value );
            }
        }

		SetMap( Output.Map ?? Package.Info.DefaultMap );
	}

	private void SetMap( string map )
	{
		Map = map;
		Output = Output with { Map = map };
	}

	List<Option> GetOptions( GameSetting e )
	{
		var options = new List<Option>();

		foreach ( var o in e.Options )
		{
			options.Add( new Option( o.Name.ToTitleCase(), o.Name ) { Icon = o.Icon } );
		}

		return options;
	}

	private string GetDefaultValue( GameSetting setting )
	{
		if ( !HasOptions( setting ) ) return setting.Default ?? string.Empty;

		return GetOptionValue( setting, setting.Default );
	}

    private string GetOptionValue( GameSetting setting, string value )
    {
        var option = setting.Options.FirstOrDefault( x => string.Equals( x.Name, value, StringComparison.OrdinalIgnoreCase ) );
        if ( !string.IsNullOrEmpty( option.Name ) ) return option.Name;

        return setting.Options[0].Name ?? string.Empty;
    }

	public bool HasOptions( GameSetting entry )
	{
		return entry.Options is not null && entry.Options.Count > 0;
	}

	public bool IsNumeric( GameSetting entry, out float flValue )
	{
		flValue = default;

		if ( float.TryParse( entry.Default, out var fl ) )
		{
			flValue = fl;
			return true;
		}
		return false;
	}

	public bool IsCheckbox( GameSetting entry )
	{
		// 0 or 1, no min, no max, no steps. Could easily be a bool
		var canPassAsBool = ( entry.Default.Equals( "0" ) || entry.Default.Equals( "1" ) ) && entry.Min is null && entry.Max is null && entry.Step is null;

		if ( canPassAsBool ) return true;

		if ( bool.TryParse( entry.Default, out var b ) )
			return true;

		return false;
	}

	bool NeedsMap()
	{   
		if ( Package is null ) return false;
		if ( Package.Info.NeedsMap ) return true;

		// legacy
		var launchMode = Package.Info.LaunchMode;
		return string.Equals( launchMode, "launcher", StringComparison.OrdinalIgnoreCase );
	}

	void OnMapSelected( string map )
	{
		SetMap( map );
		StateHasChanged();
    }

    private string GetGroupName( string group )
    {
        if ( string.IsNullOrEmpty( group ) )
        {
            return "General";
        }
        return group;
    }

    public void OnSave()
    {
        Output = Output with { MaxPlayers = Players, ServerName = ServerName, Privacy = Privacy };

        Game.Cookies.Set( CookieName, Output );

        OnComplete?.Invoke( Output );
        CloseModal( true );
    }

    string ActiveClass( string tab )
    {
        if ( tab == "General" && CurrentTabName == "General" ) return "active";
        if ( CurrentTabName == tab ) return "active";
        return default;
    }
}
